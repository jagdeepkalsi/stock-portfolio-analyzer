# Data provider selection (finnhub | yfinance | alpha_vantage)
DATA_PROVIDER=finnhub

# Finnhub API key (required for DATA_PROVIDER=finnhub and news alerts)
FINNHUB_API_KEY=your-finnhub-api-key

# Alpha Vantage API Configuration (required only if DATA_PROVIDER=alpha_vantage)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Email Configuration
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# For Gmail, use an App Password instead of your regular password
# Enable 2FA and generate an App Password at: https://myaccount.google.com/apppasswords